// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SyncState {
  id          Int      @id @default(1)
  lastLedger  Int      @default(0)
  ledgerHash  String?
  updatedAt   DateTime @updatedAt
}

model Listing {
  listingId       BigInt   @id
  artist          String
  owner           String?
  price           Decimal  @db.Decimal(32, 7)
  currency        String
  metadataCid     String
  token           String
  status          String   // "Active", "Sold", "Cancelled", "Auction"
  royaltyBps      Int      @default(0)
  createdAtLedger Int
  updatedAtLedger Int
  @@index([artist])
  @@index([status])
}

model MarketplaceEvent {
  id              Int      @id @default(autoincrement())
  listingId       BigInt?
  eventType       String   // "LISTING_CREATED", "ARTWORK_SOLD", etc.
  actor           String
  data            Json
  ledgerSequence  Int
  ledgerTimestamp DateTime @default(now())
  @@index([actor])
  @@index([eventType])
}

model Collection {
  id              Int      @id @default(autoincrement())
  contractAddress String   @unique
  kind            String   // "normal_721" | "normal_1155" | "lazy_721" | "lazy_1155"
  creator         String
  name            String?
  symbol          String?
  deployedAtLedger Int
  createdAt       DateTime @default(now())
  @@index([creator])
}
