# ─────────────────────────────────────────────────────────
# Afristore Frontend — Environment Variables
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────

# ── Stellar / Soroban ─────────────────────────────────────

## Deployed Soroban contract ID (from scripts/deploy/deploy_contract.sh)
NEXT_PUBLIC_CONTRACT_ID=

## Deployed Soroban launchpad contract ID (from scripts/deploy/deploy_launchpad.sh)
NEXT_PUBLIC_LAUNCHPAD_CONTRACT_ID=

## Base URL for the application (no trailing slash)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

## Afristore indexer HTTP base URL (no trailing slash) — used for activity & royalty APIs
NEXT_PUBLIC_INDEXER_URL=http://localhost:4000

## Network: "testnet" or "mainnet"
NEXT_PUBLIC_STELLAR_NETWORK=testnet

## Soroban RPC endpoint
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

## Horizon REST API endpoint
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

## Network passphrase (matches the network above)
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ── IPFS / Pinata ──────────────────────────────────────────

## Pinata JWT — obtained from app.pinata.cloud → API Keys
PINATA_JWT=

## Pinata dedicated IPFS gateway (include https://)
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# ── Magic.link ─────────────────────────────────────────────

## Magic.link API Key — obtained from dashboard.magic.link
## Enables email/passkey wallet abstraction for non-crypto users
NEXT_PUBLIC_MAGIC_API_KEY=

# ── Sentry (Error Monitoring) ──────────────────────────────

## Sentry DSN — obtained from sentry.io project settings
## Enables real-time error tracking and performance monitoring
NEXT_PUBLIC_SENTRY_DSN=

## Sentry organization slug (for source map uploads)
SENTRY_ORG=

## Sentry project name (for source map uploads)
SENTRY_PROJECT=

## Sentry auth token (for source map uploads in CI/CD)
SENTRY_AUTH_TOKEN=

# ── PostHog (Analytics) ────────────────────────────────────

## PostHog API Key — obtained from posthog.com project settings
## Enables privacy-first user analytics and feature tracking
NEXT_PUBLIC_POSTHOG_KEY=

## PostHog API Host (default: https://app.posthog.com)
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
